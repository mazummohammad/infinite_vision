{
    "expo": {
        "name": "MindCalm",
        "slug": "expo-app",
        "version": "1.0.0",
        "orientation": "portrait",
        "scheme": "mindcalm",
        "userInterfaceStyle": "automatic",
        "newArchEnabled": true,
        "ios": {
            "supportsTablet": true
        },
        "web": {
            "bundler": "metro",
            "output": "static"
        },
        "plugins": [
            "expo-router"
        ],
        "experiments": {
            "typedRoutes": true
        }
    }
}